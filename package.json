{
  "name": "bailongma",
  "productName": "Bailongma",
  "version": "2.1.435",
  "description": "A continuously running digital consciousness framework",
  "type": "module",
  "main": "electron/main.cjs",
  "author": {
    "name": "xiaoyuanda666-ship-it"
  },
  "scripts": {
    "start": "electron .",
    "start:lan": "powershell -ExecutionPolicy Bypass -File scripts/start-lan.ps1 app",
    "start:backend": "node --env-file=.env src/index.js",
    "start:backend:lan": "powershell -ExecutionPolicy Bypass -File scripts/start-lan.ps1 backend",
    "dev": "node --env-file=.env --watch src/index.js",
    "build": "node scripts/prebuild-clean.mjs && node scripts/build-macos-speech.mjs && node ./node_modules/@electron/rebuild/lib/cli.js -f -w better-sqlite3 -v 33.4.11 && node ./node_modules/electron-builder/cli.js",
    "build:win": "node scripts/prebuild-clean.mjs && node scripts/build-macos-speech.mjs && node ./node_modules/@electron/rebuild/lib/cli.js -f -w better-sqlite3 -v 33.4.11 && node ./node_modules/electron-builder/cli.js --win",
    "build:mac": "node scripts/build-mac.mjs",
    "build:mac:x64": "node scripts/build-mac.mjs x64",
    "build:mac:arm64": "node scripts/build-mac.mjs arm64",
    "build:linux": "node scripts/build-linux.mjs",
    "build:linux:x64": "node scripts/build-linux.mjs x64",
    "build:linux:arm64": "node scripts/build-linux.mjs arm64",
    "publish": "node scripts/prebuild-clean.mjs && node scripts/build-macos-speech.mjs && node ./node_modules/@electron/rebuild/lib/cli.js -f -w better-sqlite3 -v 33.4.11 && node ./node_modules/electron-builder/cli.js --publish always",
    "test:node": "node --test",
    "test:web:build": "node scripts/test-web-build.mjs",
    "test:web": "node --test tests/*.test.mjs",
    "test": "node --test tests/*.test.mjs",
    "postinstall": "node ./node_modules/electron-builder/cli.js install-app-deps"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.8.0",
    "cheerio": "1.0.0",
    "chokidar": "^4.0.3",
    "electron-builder": "^25.1.8",
    "express": "^5.1.0",
    "follow-redirects": "^1.15.9",
    "glob": "^11.0.1",
    "htmlparser2": "^10.0.0",
    "jsdom": "^26.1.0",
    "jsonrepair": "^3.12.0",
    "mammoth": "^1.9.0",
    "minimist": "^1.2.8",
    "openai": "^4.89.0",
    "proxy-agent": "^6.5.0",
    "puppeteer": "^24.6.1",
    "qrcode": "^1.5.4",
    "uuid": "^11.1.0",
    "wav-encoder": "^1.3.0",
    "ws": "^8.18.1",
    "xlsx": "^0.18.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "electron-builder",
      "fsevents",
      "onnxruntime-node"
    ]
  }
}